     },
     "elements": []
    },
    {
     "id": "lb000040",
     "elType": "widget",
     "widgetType": "text-editor",
     "settings": {
      "editor": "<p>Ein klar definierter Prozess &mdash; vom Antrag bis zur Listung in der Produktdatenbank.</p>"
     },
     "elements": []
    },
    {
     "id": "lb000041",
     "elType": "widget",
     "widgetType": "html",
     "settings": {
      "html": "<div class=\"proc\"><div class=\"proc-step\"><div class=\"proc-step__n\">1</div><div class=\"proc-step__t\">Antrag &amp; Selbstauskunft</div><div class=\"proc-step__d\">Produktdaten einreichen, Selbstauskunft zu den Nachhaltigkeitskriterien ausf\u00fcllen.</div></div><div class=\"proc-step is-active\"><div class=\"proc-step__n\">2</div><div class=\"proc-step__t\">Kriterienpr\u00fcfung</div><div class=\"proc-step__d\">Abgleich mit dem Kriterienkatalog und der EmpCo-Richtlinie.</div></div><div class=\"proc-step\"><div class=\"proc-step__n\">3</div><div class=\"proc-step__t\">Bewertung &amp; Award</div><div class=\"proc-step__d\">Fachliche Bewertung und Einstufung des Produkts (Non-Life Award).</div></div><div class=\"proc-step\"><div class=\"proc-step__n\">4</div><div class=\"proc-step__t\">Siegel &amp; Listung</div><div class=\"proc-step__d\">Vergabe des Siegels und Aufnahme in die \u00f6ffentliche Produktdatenbank.</div></div></div>"
     },
     "elements": []
    }
   ],
