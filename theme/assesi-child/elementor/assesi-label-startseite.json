     "elType": "widget",
     "widgetType": "html",
     "settings": {
      "html": "<footer class=\"footer\"><div class=\"footer__in\"><div class=\"footer__brand\"><span class=\"brand__name\" style=\"font-family:var(--font-display);font-weight:800;font-size:1.2rem;color:#fff\">ASSESI Label</span><p class=\"footer__tag\">Das Siegel f\u00fcr nachhaltige Versicherungsprodukte &mdash; gepr\u00fcft nach dem ASSESI-Standard, EmpCo-konform.</p><a class=\"footer__cross\" href=\"https://assesi.eu/\">&rarr; Zum Verband: assesi.eu</a></div><div class=\"footer__col\"><h4>Navigation</h4><a href=\"#warum\">Warum</a><a href=\"#prozess\">Zertifizierung</a><a href=\"#produkte\">Produkte</a></div><div class=\"footer__col\"><h4>Rechtliches</h4><a href=\"#\">Impressum</a><a href=\"#\">Datenschutz\u00aderkl\u00e4rung</a></div><div class=\"footer__col\"><h4>Kontakt</h4><a href=\"mailto:info@assesi-label.eu\">info@assesi-label.eu</a><a href=\"#\">Green Insurance Stiftung</a><span style=\"display:block;font-size:.85rem;color:rgba(255,255,255,.55);padding-top:6px\">Anschrift folgt</span></div></div><div class=\"footer__bar\"><div class=\"footer__bar-in\"><span>&copy; 2026 ASSESI Label &middot; Nachhaltige Versicherungsprodukte</span><span class=\"footer__legal\"><a href=\"#\">Impressum</a><a href=\"#\">Datenschutz</a><a href=\"#\">DE / EN</a></span></div></div></footer>"
