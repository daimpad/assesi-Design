      "html": "<nav class=\"nav\" aria-label=\"Hauptnavigation\"><div class=\"nav__in\"><a class=\"brand\" href=\"#\" aria-label=\"ASSESI Label Startseite\"><span class=\"brand__mark\">A</span><span><span class=\"brand__name\">ASSESI</span><span class=\"brand__tag\">Label</span></span></a><div class=\"nav__links\"><a href=\"#warum\">Warum</a><a href=\"#prozess\">Zertifizierung</a><a href=\"#produkte\">Produkte</a></div><div class=\"nav__util\"><div class=\"lang\" aria-label=\"Sprache\"><a href=\"#\" aria-current=\"true\">DE</a><a href=\"#\">EN</a></div><a class=\"nav__cross\" href=\"https://assesi.eu/\">&rarr; Verband</a><a class=\"nav__cta\" href=\"#prozess\">Siegel pr\u00fcfen</a><button class=\"nav__burger\" aria-label=\"Men\u00fc \u00f6ffnen\" aria-expanded=\"false\" aria-controls=\"navPanel\">&#9776;</button></div></div><div class=\"nav__panel\" id=\"navPanel\"><a href=\"#warum\">Warum</a><a href=\"#prozess\">Zertifizierung</a><a href=\"#produkte\">Produkte</a><a href=\"https://assesi.eu/\" class=\"nav__panel-cross\">&rarr; assesi.eu</a><a href=\"#prozess\" class=\"btn btn--cta nav__panel-cta\">Siegel pr\u00fcfen</a></div></nav>"
