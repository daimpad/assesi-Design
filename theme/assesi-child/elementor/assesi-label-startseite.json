   "elements": [
    {
     "id": "lb000027",
     "elType": "widget",
     "widgetType": "html",
     "settings": {
      "html": "<section class=\"cta-warm\" id=\"produkte\"><div class=\"section\"><div class=\"sec-head\"><div class=\"eyebrow\">Produktdatenbank</div><h2 class=\"sec-title\">Finden Sie <em>zertifizierte</em> Produkte.</h2><p class=\"sec-lede\">Bald durchsuchbar: alle Versicherungsprodukte mit ASSESI-Siegel &mdash; auf einen Blick.</p></div><div class=\"search-mock\"><input type=\"text\" readonly placeholder=\"Produkt oder Versicherer suchen \u2026\" aria-label=\"Produktsuche (in Vorbereitung)\"><button type=\"button\">Suchen</button></div><p class=\"search-note\">Die Produktdatenbank startet in einer sp\u00e4teren Phase (Platzhalter).</p><div class=\"btn-row\"><a class=\"btn btn--primary\" href=\"#prozess\">Produkt zertifizieren lassen</a><a class=\"btn btn--ghost\" href=\"#warum\">Mehr \u00fcber das Siegel</a></div></div></section>"
     },
     "elements": []
    }
