         "settings": {
          "html": "<aside class=\"std-card\" aria-label=\"Was Mitgliedschaft bedeutet\">\n<div class=\"std-card__label\">Was Mitgliedschaft bedeutet</div>\n<div class=\"std-row\"><span class=\"std-row__num\">01</span><span><span class=\"std-row__t\">Sichtbarkeit</span><span class=\"std-row__d\">Listung im Verbund europ&auml;ischer nachhaltiger Versicherer.</span></span></div>\n<div class=\"std-row\"><span class=\"std-row__num\">02</span><span><span class=\"std-row__t\">Kostentransparenz</span><span class=\"std-row__d\">Beitr&auml;ge und Leistungen offen ausgewiesen.</span></span></div>\n<div class=\"std-row\"><span class=\"std-row__num\">03</span><span><span class=\"std-row__t\">Compliance</span><span class=\"std-row__d\">Anschluss an DIN-Norm und EmpCo-Richtlinie.</span></span></div>\n<div class=\"std-card__foot\"><span>Getragen von</span><span class=\"supporter\">DBU</span><span class=\"supporter\">Green Insurance Stiftung</span></div>\n</aside>"
         },
