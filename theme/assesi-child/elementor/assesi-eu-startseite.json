    {
     "id": "025575d0",
     "elType": "widget",
     "widgetType": "html",
     "settings": {
      "html": "<div class=\"acc\" data-acc>\n  <div class=\"acc__item is-done\"><button class=\"acc__head\" aria-expanded=\"false\"><span class=\"acc__dot\">&#10003;</span><span class=\"acc__meta\"><span class=\"acc__date\">2023</span><span class=\"acc__title\">Gr&uuml;ndung des Verbands</span></span><span class=\"acc__chev\">&#9662;</span></button><div class=\"acc__panel\"><div class=\"acc__panel-inner\">Zusammenschluss der Gr&uuml;ndungsversicherer; Definition von Auftrag, Governance und Zielbild des Standards.</div></div></div>\n  <div class=\"acc__item is-done\"><button class=\"acc__head\" aria-expanded=\"false\"><span class=\"acc__dot\">&#10003;</span><span class=\"acc__meta\"><span class=\"acc__date\">2024</span><span class=\"acc__title\">DIN-Normungsverfahren 77237</span></span><span class=\"acc__chev\">&#9662;</span></button><div class=\"acc__panel\"><div class=\"acc__panel-inner\">Einbringung des Standards in das formelle Normungsverfahren als belastbare, geteilte Grundlage.</div></div></div>\n  <div class=\"acc__item is-active\"><button class=\"acc__head\" aria-expanded=\"true\"><span class=\"acc__dot\">3</span><span class=\"acc__meta\"><span class=\"acc__date\">2025 &middot; laufend</span><span class=\"acc__title\">DBU-F&ouml;rderung &amp; Pilotmitglieder</span></span><span class=\"acc__chev\">&#9662;</span></button><div class=\"acc__panel\"><div class=\"acc__panel-inner\">Aufbau der Webpr&auml;senz und Gewinnung erster Pilotversicherer im F&ouml;rderzeitraum der DBU.</div></div></div>\n  <div class=\"acc__item is-future\"><button class=\"acc__head\" aria-expanded=\"false\"><span class=\"acc__dot\">4</span><span class=\"acc__meta\"><span class=\"acc__date\">2026</span><span class=\"acc__title\">Anschlussfinanzierung</span></span><span class=\"acc__chev\">&#9662;</span></button><div class=\"acc__panel\"><div class=\"acc__panel-inner\">Tragf&auml;higkeit des Verbands &uuml;ber Mitgliedsbeitr&auml;ge nach Auslaufen der F&ouml;rderung.</div></div></div>\n</div>"
     },
     "elements": []
    }
   ],
   "isInner": false
