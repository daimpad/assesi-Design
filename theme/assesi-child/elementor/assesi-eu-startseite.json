     "elType": "widget",
     "widgetType": "html",
     "settings": {
      "html": "<footer class=\"footer\">\n  <div class=\"footer__in\">\n    <div class=\"footer__brand\">\n      <span class=\"brand__name\" style=\"font-family:var(--font-display);font-weight:800;font-size:1.2rem;color:#fff\">ASSESI</span>\n      <p class=\"footer__tag\">Association of European Sustainable Insurers &mdash; der normbasierte Standard f&uuml;r nachhaltige Versicherer in Europa.</p>\n      <a class=\"footer__cross\" href=\"#\">&rarr; Zum Siegel: assesi-label.eu</a>\n    </div>\n    <div class=\"footer__col\"><h4>Navigation</h4><a href=\"#was\">Was ist ASSESI</a><a href=\"#vorteile\">Vorteile</a><a href=\"#verlauf\">Verlauf</a><a href=\"#mitmachen\">Mitmachen</a></div>\n    <div class=\"footer__col\"><h4>Rechtliches</h4><a href=\"#\">Impressum</a><a href=\"#\">Datenschutzerkl&auml;rung</a></div>\n    <div class=\"footer__col\"><h4>Kontakt</h4><a href=\"#\">info@assesi.eu</a><a href=\"#\">Green Insurance Stiftung</a><span style=\"display:block;font-size:.85rem;color:rgba(255,255,255,.55);padding-top:6px\">Anschrift folgt</span></div>\n  </div>\n  <div class=\"footer__bar\"><div class=\"footer__bar-in\"><span>&copy; 2026 ASSESI &middot; Association of European Sustainable Insurers</span><span class=\"footer__legal\"><a href=\"#\">Impressum</a><a href=\"#\">Datenschutz</a><a href=\"#\">DE / EN</a></span></div></div>\n</footer>"
