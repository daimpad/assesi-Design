    {
     "id": "a378ec81",
     "elType": "widget",
     "widgetType": "html",
     "settings": {
      "html": "<section class=\"cta-band\" id=\"mitmachen\">\n  <div class=\"section\">\n    <div class=\"cta-grid\">\n      <div>\n        <div class=\"eyebrow\">Mitmachen</div>\n        <h2 class=\"sec-title\">Werden Sie Teil des <em>Standards</em>.</h2>\n        <p class=\"cta-lede\">Transparente Beitr&auml;ge, klarer Gegenwert. Die Mitgliedschaft tr&auml;gt den Verband &mdash; und macht Ihre Nachhaltigkeit sichtbar und pr&uuml;fbar.</p>\n        <div class=\"btn-row\">\n          <a class=\"btn btn--cta\" href=\"#\">Mitglied werden</a>\n          <a class=\"btn btn--ghost-dark\" href=\"#\">Beitrag anfragen</a>\n        </div>\n      </div>\n      <aside class=\"price-card\" id=\"kosten\">\n        <div class=\"price-card__label\">Was enthalten ist</div>\n        <ul class=\"price-list\">\n          <li><svg viewBox=\"0 0 24 24\"><path d=\"M5 13l4 4L19 7\"/></svg>Listung im europ&auml;ischen Verbund</li>\n          <li><svg viewBox=\"0 0 24 24\"><path d=\"M5 13l4 4L19 7\"/></svg>Nutzung des ASSESI-Siegels</li>\n          <li><svg viewBox=\"0 0 24 24\"><path d=\"M5 13l4 4L19 7\"/></svg>Mitgestaltung des Standards</li>\n          <li><svg viewBox=\"0 0 24 24\"><path d=\"M5 13l4 4L19 7\"/></svg>Teilnahme an Verbandsveranstaltungen</li>\n        </ul>\n        <div class=\"price-foot\">\n          <div class=\"price-foot__k\">Beitrag</div>\n          <div class=\"price-foot__v\">Gestaffelt nach Beitragsvolumen<small>Konkrete Beitragsstaffel wird von ASSESI festgelegt (Platzhalter).</small></div>\n        </div>\n      </aside>\n    </div>\n  </div>\n</section>"
     },
     "elements": []
    }
   ],
   "isInner": false
  },
