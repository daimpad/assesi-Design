   },
   "elements": [
    {
     "id": "0af4cfff",
     "elType": "widget",
     "widgetType": "html",
     "settings": {
      "html": "<header class=\"hero\">\n  <div class=\"hero__copy\">\n    <div class=\"hero__eyebrow\">DIN 77237 &middot; Verband</div>\n    <h1>Der europ&auml;ische Standard f&uuml;r <em>nachhaltige Versicherer</em>.</h1>\n    <p class=\"hero__lede\">ASSESI macht Nachhaltigkeit in der Versicherungswirtschaft pr&uuml;fbar &mdash; normbasiert, transparent und von seinen Mitgliedern getragen.</p>\n    <div class=\"btn-row\">\n      <a class=\"btn btn--primary\" href=\"#mitmachen\">Mitglied werden</a>\n      <a class=\"btn btn--cta\" href=\"#kosten\">Kosten ansehen</a>\n      <a class=\"btn btn--ghost\" href=\"#was\">Was ist ASSESI?</a>\n    </div>\n    <div class=\"hero__trust\">\n      <span class=\"trust__item\">DBU-gef&ouml;rdert</span><span class=\"trust__item\">DIN 77237 in Arbeit</span><span class=\"trust__item\">EmpCo-Richtlinie</span>\n    </div>\n  </div>\n  <aside class=\"std-card\" aria-label=\"Was Mitgliedschaft bedeutet\">\n    <div class=\"std-card__label\">Was Mitgliedschaft bedeutet</div>\n    <div class=\"std-row\"><span class=\"std-row__num\">01</span><span><span class=\"std-row__t\">Sichtbarkeit</span><span class=\"std-row__d\">Listung im Verbund europ&auml;ischer nachhaltiger Versicherer.</span></span></div>\n    <div class=\"std-row\"><span class=\"std-row__num\">02</span><span><span class=\"std-row__t\">Kostentransparenz</span><span class=\"std-row__d\">Beitr&auml;ge und Leistungen offen ausgewiesen.</span></span></div>\n    <div class=\"std-row\"><span class=\"std-row__num\">03</span><span><span class=\"std-row__t\">Compliance</span><span class=\"std-row__d\">Anschluss an DIN-Norm und EmpCo-Richtlinie.</span></span></div>\n    <div class=\"std-card__foot\"><span>Getragen von</span><span class=\"supporter\">DBU</span><span class=\"supporter\">Green Insurance Stiftung</span></div>\n  </aside>\n</header>"
     },
     "elements": []
    }
   ],
   "isInner": false
  },
