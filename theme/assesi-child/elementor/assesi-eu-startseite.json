     "settings": {
      "html": "<nav class=\"nav\" aria-label=\"Hauptnavigation\">\n  <div class=\"nav__in\">\n    <a class=\"brand\" href=\"#\" aria-label=\"ASSESI Startseite\">\n      <span class=\"brand__mark\">A</span>\n      <span><span class=\"brand__name\">ASSESI</span><span class=\"brand__tag\">Sustainable Insurers</span></span>\n    </a>\n    <div class=\"nav__links\">\n      <a href=\"#was\">Was ist ASSESI</a><a href=\"#vorteile\">Vorteile</a><a href=\"#verlauf\">Verlauf</a><a href=\"#mitmachen\">Mitmachen</a>\n    </div>\n    <div class=\"nav__util\">\n      <div class=\"lang\" aria-label=\"Sprache\"><a href=\"#\" aria-current=\"true\">DE</a><a href=\"#\">EN</a></div>\n      <a class=\"nav__lime\" href=\"https://assesi-label.eu/\">Zum Siegel</a>\n      <a class=\"nav__cta\" href=\"#mitmachen\">Mitglied werden</a>\n      <button class=\"nav__burger\" aria-label=\"Men&uuml; &ouml;ffnen\" aria-expanded=\"false\" aria-controls=\"navPanel\">&#9776;</button>\n    </div>\n  </div>\n  <div class=\"nav__panel\" id=\"navPanel\">\n    <a href=\"#was\">Was ist ASSESI</a><a href=\"#vorteile\">Vorteile</a><a href=\"#verlauf\">Verlauf</a><a href=\"#mitmachen\">Mitmachen</a>\n    <a href=\"https://assesi-label.eu/\" class=\"btn nav__panel-lime\">Zum Siegel</a>\n    <a href=\"#mitmachen\" class=\"btn btn--cta nav__panel-cta\">Mitglied werden</a>\n  </div>\n</nav>"
     },
